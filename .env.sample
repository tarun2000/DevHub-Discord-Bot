# Discord bot and backend settings
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-app-client-id
# Optional: limit commands registration to a guild for faster dev
DISCORD_GUILD_ID=optional-dev-guild-id

# Backend URL (used by the bot to call the API). Default when omitted: http://localhost:3000
BACKEND_URL=http://localhost:3000

# Server port
PORT=3000

 Database connection string (PostgreSQL)
DATABASE_URL="Insert your database connection string here"
