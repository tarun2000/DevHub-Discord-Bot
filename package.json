{
  "name": "devhub-proj",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "ts-node-esm --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "bot": "ts-node-esm src/bot/run.ts",
    "dev:all": "concurrently \"npm:dev\" \"npm:bot\""
  },
  "dependencies": {
    "@prisma/client": "^5.5.0",
    "axios": "^1.5.0",
    "cors": "^2.8.5",
    "discord.js": "^14.11.0",
    "dotenv": "^16.1.4",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "concurrently": "^8.2.0",
    "prisma": "^5.5.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
